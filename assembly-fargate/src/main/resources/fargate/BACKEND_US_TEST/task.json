{
  "family": "backend-task-test",
  "executionRoleArn": "arn:aws:iam::060758616165:role/backend-ecs-execution-role-us-east-1",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "060758616165.dkr.ecr.us-east-1.amazonaws.com/backend:latest",
      "cpu": 1024,
      "memory": 2048,
      "memoryReservation": 1024,
      "portMappings": [
        {
          "hostPort": 8081,
          "containerPort": 8081,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "entryPoint": ["sh", "-c", "/backend/run.sh"],
      "workingDirectory": "/backend",
      "environment": [
        { "name": "HUB", "value": "US" },
        { "name": "INITIAL_START", "value": "true" },
        { "name": "REGION", "value": "us-east-1" },
        { "name": "STAGE", "value": "TEST" }
      ],
      "secrets": [
        {
          "name": "SPRING_APPLICATION_JSON",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:060758616165:secret:backend-secretsmanager-test-us-east-1"
        }
      ],
      "dockerLabels": {
        "PROMETHEUS_EXPORTER_PORT": "8081",
        "PROMETHEUS_EXPORTER_PATH": "/backend/status/v1/prometheus",
        "application": "backend",
        "PROMETHEUS_EXPORTER_JOB_NAME": "backend"
      }
    }
  ],
  "taskRoleArn": "arn:aws:iam::060758616165:role/backend-ecs-task-role-us-east-1",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "1024",
  "memory": "2048"
}